{
  "title": "Green Cache Dashboard",
  "uid": "green-cache-main",
  "timezone": "browser",
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 0.5}, {"color": "green", "value": 0.8}]},
          "unit": "percentunit"
        }
      },
      "targets": [{"expr": "green_cache_hit_rate", "datasource": {"type": "prometheus"}}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 2,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [{"expr": "sum(green_cache_requests_total)", "datasource": {"type": "prometheus"}}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 3,
      "title": "Water Saved (Liters)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 6, "color": {"mode": "fixed", "fixedColor": "blue"}}},
      "targets": [{"expr": "sum(green_cache_water_saved_liters)", "datasource": {"type": "prometheus"}}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 4,
      "title": "Energy Saved (Wh)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "fieldConfig": {"defaults": {"unit": "watth", "color": {"mode": "fixed", "fixedColor": "yellow"}}},
      "targets": [{"expr": "sum(green_cache_energy_saved_wh_total)", "datasource": {"type": "prometheus"}}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 5,
      "title": "Request Latency (seconds)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {"expr": "rate(green_cache_request_latency_seconds_sum[1m]) / rate(green_cache_request_latency_seconds_count[1m])", "legendFormat": "avg latency", "datasource": {"type": "prometheus"}}
      ],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 6,
      "title": "Tokens Saved Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"expr": "sum(green_cache_tokens_saved_total)", "legendFormat": "tokens saved", "datasource": {"type": "prometheus"}}
      ],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 7,
      "title": "Cache Entries",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 4},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [{"expr": "green_cache_entries", "datasource": {"type": "prometheus"}}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 8,
      "title": "Carbon Saved (g)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "fixed", "fixedColor": "green"}}},
      "targets": [{"expr": "sum(green_cache_carbon_saved_g_total)", "datasource": {"type": "prometheus"}}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    }
  ],
  "schemaVersion": 38
}
