# Cache Configuration
CACHE_BACKEND=memory
SIMILARITY_THRESHOLD=0.60

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
