# LLM Provider: ollama | groq | openai | deepseek
LLM_PROVIDER=groq

# Groq (free tier - 14,400 requests/day, 30 req/min)
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile

# DeepSeek (backup)
# DEEPSEEK_API_KEY=
